# >>> agent-kit gitignore (managed) >>>
# --- agent-kit additions ---
# Per-session agent transient state
.claude/scheduled_tasks.lock
# MCP config — keep local or symlinked from a trusted local source
.mcp.json
# Codex local marker
.codex
# Per-worktree env (collision-avoidance ports + derived connection strings)
.env.local
# Per-worktree Doppler scope binding (if you use Doppler)
.doppler.yaml
# Playwright MCP transient state
.playwright-mcp/
# --- end agent-kit additions ---
# <<< agent-kit gitignore (managed) <<<

# Node
node_modules/
.npm/
*.log
.DS_Store

# Local env
.env
.env.*.local
!.env.example
