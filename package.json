{
  "name": "startup-state-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev --port ${PORT:-3000}",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --port ${WRANGLER_PORT:-8787}",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply startup-state-atlas-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply startup-state-atlas-db --remote",
    "auth:generate": "better-auth generate",
    "seed": "tsx db/seed/index.ts",
    "bootstrap-superadmin": "tsx scripts/bootstrap-superadmin.ts",
    "cli": "tsx cli/index.ts",
    "mcp": "tsx mcp/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "@base-ui/react": "^1.4.1",
    "@opennextjs/cloudflare": "^1.0.0",
    "better-auth": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^4.7.0",
    "nanoid": "^5.0.0",
    "next": "15.5.18",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^4.0.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.2.0",
    "@cloudflare/workers-types": "^4.20251001.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "wrangler": "^4.0.0"
  }
}
