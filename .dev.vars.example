# Wrangler local secrets — copy to `.dev.vars` (gitignored) and fill in values.
#
# WHY THIS FILE EXISTS, NOT JUST `.env.local`:
# Code in `lib/` reads secrets via `env().X` (Cloudflare context binding),
# which `@opennextjs/cloudflare`'s `initOpenNextCloudflareForDev()` populates
# from `.dev.vars` when running `npm run dev`. Values in `.env.local` are
# only visible as `process.env.X` (Next.js convention) — they don't reach
# `env()` calls, so the lib helpers can't see them.
#
# In production, the same names are set as Worker secrets via
# `wrangler secret put` and read by the same `env().X` calls.
#
# `.env.local` keeps PORT / WRANGLER_PORT and any drizzle-kit / wrangler CLI
# credentials (those tools read process.env directly).
#
# Per-worktree note: `BETTER_AUTH_URL` includes a port; main checkout uses
# 3000, worktrees use 3000+N (see `docs/agent-tasks/00-shared-context.md`
# § Worktree port table). Adjust to match the worktree you're filling this
# out in.

ANTHROPIC_API_KEY=
ATLAS_ADMIN_TOKEN=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
RESEND_API_KEY=

# R2 S3-compat credentials for signing OWNERSHIP_DOCS doc previews
# (60-second presigned GET URLs in /admin/submissions/[id]).
# Generate at: Cloudflare dashboard → R2 → Manage R2 API Tokens → Create.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------
# Local-dev auth DX (NEVER set these in production).
# Full guidance: CLAUDE.md § Local authentication testing.
# ---------------------------------------------------------------------
#
# Skip OTP entirely. Signups auto-verify and land on the authenticated
# page with no second prompt. Best for inner-loop work.
# AUTH_SKIP_OTP=true
#
# Mailpit transport. Routes outgoing email to mailpit's HTTP send API;
# the same port serves the inbox UI in your browser. Mailpit is shared
# across all worktrees (single host install).
#   docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
#   # or: brew install mailpit && mailpit
# MAILPIT_URL=http://localhost:8025
