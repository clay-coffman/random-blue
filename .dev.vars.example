# Wrangler local secrets — copy to `.dev.vars` (gitignored) and fill in values.
#
# WHY THIS FILE EXISTS, NOT JUST `.env.local`:
# Code in `lib/` reads secrets via `env().X` (Cloudflare context binding),
# which `@opennextjs/cloudflare`'s `initOpenNextCloudflareForDev()` populates
# from `.dev.vars` when running `npm run dev`. Values in `.env.local` are
# only visible as `process.env.X` (Next.js convention) — they don't reach
# `env()` calls, so the lib helpers can't see them.
#
# In production, the same names are set as Worker secrets via
# `wrangler secret put` and read by the same `env().X` calls.
#
# `.env.local` keeps PORT / WRANGLER_PORT and any drizzle-kit / wrangler CLI
# credentials (those tools read process.env directly).

ANTHROPIC_API_KEY=
ATLAS_ADMIN_TOKEN=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
RESEND_API_KEY=
