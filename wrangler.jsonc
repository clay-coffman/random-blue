{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "startup-state-atlas",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Custom domain. `custom_domain: true` makes Cloudflare manage the
  // DNS record and the SSL cert automatically — no separate route or
  // CNAME-setup dance. Apex + www both point at the Worker so either
  // form serves the app.
  //
  // TODO: pin `"workers_dev": false` here once the CF API token is
  // granted Zone:Workers Routes:Edit on startupstateatlas.dev.
  // Wrangler needs that permission to verify the workers_dev flag
  // against the zone's existing routes; without it the deploy fails
  // with code 10000. Workers_dev IS already off (verified: GET
  // https://startup-state-atlas.claymcoffman.workers.dev/ returns
  // 404), so this is just belt-and-suspenders. The real defense is
  // the gate, not the URL surface.
  "routes": [
    { "pattern": "startupstateatlas.dev", "custom_domain": true },
    { "pattern": "www.startupstateatlas.dev", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "startup-state-atlas-db",
      "database_id": "698139c1-1b46-456f-a4fe-6206a8c204bb",
      "migrations_dir": "db/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "OWNERSHIP_DOCS",
      "bucket_name": "atlas-ownership-docs"
    }
  ],
  // Cloudflare's native Rate Limiting bindings. Fixed-window per key,
  // evaluated in-edge with no DB writes. `key` is the IP (cf-connecting-ip)
  // supplied at call time. Per-Worker `namespace_id` integers — no global
  // registry, just don't collide within this Worker.
  //
  // Better Auth's auth-route limits are separate and live in D1 — see
  // the `rateLimit` block in auth.ts.
  //
  // 1101 — UPLOAD_LIMIT          — POST /api/v1/ownership-submissions
  // 1102 — GATE_LIMIT            — POST /api/gate (preview password gate)
  // 1103 — RECOMMEND_LIMIT       — POST /api/v1/resources/recommend (Claude)
  // 1104 — ENRICH_LIMIT          — POST /api/v1/founder-passports/enrich (Claude)
  // 1105 — PASSPORT_LIMIT        — POST /api/v1/founder-passports
  // 1106 — INVESTOR_BRIEF_LIMIT  — POST /api/v1/companies/investor-brief (Claude)
  "unsafe": {
    "bindings": [
      {
        "name": "UPLOAD_LIMIT",
        "type": "ratelimit",
        "namespace_id": "1101",
        "simple": { "limit": 10, "period": 60 }
      },
      {
        "name": "GATE_LIMIT",
        "type": "ratelimit",
        "namespace_id": "1102",
        "simple": { "limit": 10, "period": 60 }
      },
      {
        "name": "RECOMMEND_LIMIT",
        "type": "ratelimit",
        "namespace_id": "1103",
        "simple": { "limit": 5, "period": 60 }
      },
      {
        "name": "ENRICH_LIMIT",
        "type": "ratelimit",
        "namespace_id": "1104",
        "simple": { "limit": 5, "period": 60 }
      },
      {
        "name": "PASSPORT_LIMIT",
        "type": "ratelimit",
        "namespace_id": "1105",
        "simple": { "limit": 10, "period": 60 }
      },
      {
        "name": "INVESTOR_BRIEF_LIMIT",
        "type": "ratelimit",
        "namespace_id": "1106",
        "simple": { "limit": 5, "period": 60 }
      }
    ]
  }
}
