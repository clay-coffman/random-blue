# Anthropic
ANTHROPIC_API_KEY=

# Cloudflare account (used by drizzle-kit's d1-http driver and wrangler)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Filled in by Agent 0 after `wrangler d1 create startup-state-atlas-db`.
D1_DATABASE_ID=

# Machine-client auth (CLI / MCP) — replace in prod.
ATLAS_ADMIN_TOKEN=dev-only-replace-me

# Better Auth (humans). 32+ random bytes in prod.
BETTER_AUTH_SECRET=dev-only-replace-me-32-chars-min
BETTER_AUTH_URL=http://localhost:3000

# Resend (email verification + password reset)
RESEND_API_KEY=

# Worktree ports (formula: PORT=3000+N, WRANGLER_PORT=8787+N).
PORT=3000
WRANGLER_PORT=8787

# Pre-launch site-wide preview gate. UNSET means the gate is disabled
# (every visitor reaches the app directly). When set, every Next route
# and every API handler redirects to /gate until the visitor submits
# this password. To demo without the gate:
#   wrangler secret delete SITE_PASSWORD && npm run deploy
#
# IMPORTANT — `lib/site-gate.ts` reads SITE_PASSWORD via `process.env`
# (NOT via `env()` from `lib/cf.ts`) because middleware runs in a
# context where the Cloudflare binding helper isn't always available.
# That means the gate is configured here in `.env.local`, NOT in
# `.dev.vars` like the other secrets. If you put it in `.dev.vars`,
# the gate will silently no-op locally.
SITE_PASSWORD=
