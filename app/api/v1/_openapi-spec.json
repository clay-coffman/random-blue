          },
          "linkedin": {
            "type": "string",
            "nullable": true
          },
          "claimed_by_user_id": {
            "type": "string",
            "nullable": true
          },
          "verified_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "claimed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "CompanyPatch": {
        "type": "object",
        "description": "Partial update. Owner edits accept only the whitelisted keys\nbelow. Admin / machine token may also send `slug`, `linkedin`,\nand `address_text`.\n",
        "properties": {
          "name": {
            "type": "string"
          },
