          },
          "logo_url": {
            "type": "string",
            "format": "uri"
          },
          "founder_team_json": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "slug": {
            "type": "string",
